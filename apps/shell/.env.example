# Build-time constants (VITE_ prefix required for client exposure)
# These are baked into the JS bundle at build time.
# Runtime configuration (OIDC, API URL) is in public/config.json instead.

# Application version — displayed in status bar (future use)
VITE_APP_VERSION=0.0.0-dev

# API version — used for API path prefixing (future use)
VITE_API_VERSION=v1
