{
  "name": "@hexalith/shell",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit --project tsconfig.build.json",
    "build": "pnpm run typecheck && vite build",
    "preview": "vite preview",
    "lint": "eslint src vite.config.ts vitest.config.ts eslint.config.js",
    "test": "vitest run",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hexalith/cqrs-client": "workspace:*",
    "@hexalith/shell-api": "workspace:*",
    "@hexalith/ui": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-oidc-context": "^3.3.0",
    "react-router": "^7.6.0"
  },
  "devDependencies": {
    "@hexalith/eslint-config": "workspace:*",
    "@hexalith/tsconfig": "workspace:*",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "esbuild": "^0.27.4",
    "fast-glob": "^3.3.3",
    "typescript": "^5.0.0",
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.50.0",
    "vite": "^6.0.0"
  }
}