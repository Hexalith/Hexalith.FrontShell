{
  "name": "@hexalith/cqrs-client",
  "version": "0.2.0",
  "type": "module",
  "description": "CQRS client hooks and utilities for Hexalith frontend modules",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "source": "./src/testing.ts",
      "import": "./dist/testing.js",
      "types": "./dist/testing.d.ts"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hexalith/Hexalith.FrontShell.git",
    "directory": "packages/cqrs-client"
  },
  "scripts": {
    "build": "tsup",
    "lint": "eslint src tsup.config.ts vitest.config.ts eslint.config.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@hexalith/shell-api": "workspace:*",
    "@microsoft/signalr": "^10.0.0",
    "ulidx": "^2.4.1",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@hexalith/eslint-config": "workspace:*",
    "@hexalith/tsconfig": "workspace:*",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^25.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
